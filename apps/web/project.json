{
  "name": "web",
  "projectType": "application",
  "root": "apps/web",
  "sourceRoot": "apps/web/src",
  "tags": ["scope:web", "type:app"],
  "targets": {
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx biome check --write apps/web packages/allowlister-remote-plugin scripts package.json package-lock.json nx.json biome.jsonc .release-please-manifest.json release-please-config.json gh-secrets.json",
        "cwd": "."
      }
    },
    "fmt-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx biome check --formatter-enabled=true --linter-enabled=false apps/web packages/allowlister-remote-plugin scripts package.json package-lock.json nx.json biome.jsonc .release-please-manifest.json release-please-config.json gh-secrets.json",
        "cwd": "."
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx biome lint apps/web packages/allowlister-remote-plugin scripts && npx knip --production",
        "cwd": "."
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc -p apps/web/tsconfig.json --noEmit",
        "cwd": "."
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vitest --config vitest.config.ts --coverage --run",
        "cwd": "apps/web"
      }
    },
    "bench": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vitest bench --config vitest.config.ts --run --outputJson ../../target/web-perf/bench.json",
        "cwd": "apps/web"
      },
      "cache": false
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx next build apps/web",
        "cwd": "."
      },
      "cache": false
    },
    "test-e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright test --config playwright.config.ts",
        "cwd": "apps/web"
      },
      "dependsOn": [
        "build",
        {
          "target": "build",
          "projects": [
            "allowlister-remote-plugin",
            "allowlister-remote-broker",
            "allowlister-remote-daemon"
          ]
        }
      ]
    },
    "capture": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright test --config apps/web/playwright.capture.config.ts",
        "cwd": "."
      },
      "dependsOn": ["build"],
      "cache": false
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx next dev apps/web",
        "cwd": "."
      }
    }
  },
  "implicitDependencies": [
    "allowlister-remote-plugin",
    "allowlister-remote-broker",
    "allowlister-remote-daemon"
  ]
}
