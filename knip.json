{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "apps/web/app/**/*.ts",
    "apps/web/app/**/*.tsx",
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "apps/web/*.config.ts",
    "apps/web/eslint.config.mjs",
    "apps/web/playwright.config.ts",
    "apps/web/screenshots/**/*.capture.ts"
  ],
  "project": [
    "apps/web/**/*.{ts,tsx}"
  ],
  "ignore": [
    "apps/web/next-env.d.ts",
    "apps/web/.next/**"
  ],
  "ignoreWorkspaces": [
    "packages/allowlister-remote-plugin"
  ],
  "ignoreDependencies": [
    "@playwright/test",
    "@testing-library/user-event",
    "class-variance-authority",
    "clsx",
    "jsdom",
    "nx",
    "tailwind-merge",
    "chrome-launcher",
    "lighthouse"
  ],
  "ignoreBinaries": [
    "biome",
    "knip",
    "tsc",
    "vitest",
    "playwright",
    "next",
    "eslint"
  ]
}
