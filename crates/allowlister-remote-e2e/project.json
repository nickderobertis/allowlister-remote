{
  "name": "allowlister-remote-e2e",
  "projectType": "application",
  "root": "crates/allowlister-remote-e2e",
  "sourceRoot": "crates/allowlister-remote-e2e/src",
  "tags": ["scope:e2e", "type:test", "lang:rust"],
  "targets": {
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo fmt --manifest-path crates/allowlister-remote-e2e/Cargo.toml",
        "cwd": "."
      }
    },
    "fmt-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo fmt --manifest-path crates/allowlister-remote-e2e/Cargo.toml --check",
        "cwd": "."
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo clippy -p allowlister-remote-e2e --all-targets -- -D warnings",
        "cwd": "."
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo check -p allowlister-remote-e2e --all-targets",
        "cwd": "."
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo test -p allowlister-remote-e2e",
        "cwd": "."
      },
      "dependsOn": [
        { "target": "build", "projects": ["allowlister-remote-broker"] },
        { "target": "build", "projects": ["allowlister-remote-daemon"] },
        { "target": "build", "projects": ["allowlister-remote-plugin"] }
      ]
    }
  }
}
