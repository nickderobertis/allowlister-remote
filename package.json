{
  "name": "allowlister-remote",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/allowlister-remote-plugin"
  ],
  "scripts": {
    "dev": "nx run web:dev",
    "build": "nx affected -t build",
    "lint": "nx affected -t lint",
    "typecheck": "nx affected -t typecheck",
    "test": "nx affected -t test",
    "format": "nx affected -t format",
    "fmt-check": "nx affected -t fmt-check",
    "test:e2e": "nx affected -t test-e2e",
    "start": "node scripts/serve-web.mjs --dir apps/web/out",
    "plugin": "cargo run --quiet -p allowlister-remote-plugin --",
    "release:set-npm-version": "node scripts/set-npm-package-version.mjs",
    "release:stage-npm": "node scripts/stage-npm-package.mjs",
    "release:stage-web": "node scripts/stage-web-package.mjs",
    "release:smoke-npm": "bash scripts/smoke-npm-package.sh",
    "release:smoke-web": "bash scripts/smoke-web-package.sh",
    "release:smoke-e2e": "bash scripts/smoke-e2e-published.sh"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "^16.2.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@biomejs/biome": "2.5.0",
    "@playwright/test": "^1.61.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "chrome-launcher": "^1.2.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "knip": "6.17.1",
    "lighthouse": "^12.8.2",
    "nx": "^23.0.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
